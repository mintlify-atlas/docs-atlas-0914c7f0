  "keyFeatures": [
    "Elm Architecture pattern with Model-Update-View",
    "Effect-TS powered side effect management",
    "Type-safe bidirectional routing with parser combinators",
    "Model-driven subscriptions and managed resources",
    "Accessible UI component primitives (Dialog, Menu, Tabs, Listbox, etc.)",
    "Field validation with discriminated unions",
    "Virtual DOM with Snabbdom",
    "State-preserving HMR with Vite plugin",
    "CLI scaffolding tool (create-foldkit-app)"
  ],
  "publicApiSurface": [
    "Runtime.makeElement",
